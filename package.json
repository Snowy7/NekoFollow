{
  "name": "neko-runner",
  "version": "0.1.0",
  "description": "A desktop cat companion built with Tauri",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "installer": "tauri build --bundles nsis",
    "installer:msi": "tauri build --bundles msi",
    "installer:all": "tauri build --bundles nsis,msi",
    "icons": "npx tauri icon src/assets/icon.svg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
