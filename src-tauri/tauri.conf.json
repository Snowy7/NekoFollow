{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neko Runner",
  "version": "0.1.0",
  "identifier": "com.snowy.neko-runner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Neko Runner",
        "label": "main",
        "width": 620,
        "height": 520,
        "minWidth": 360,
        "minHeight": 320,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "Snowy",
    "category": "Utility",
    "shortDescription": "A desktop cat companion that follows your cursor.",
    "longDescription": "Neko Runner is a lightweight desktop companion app that overlays a playful pixel cat on your screen and lets you customize its behavior and appearance.",
    "copyright": "Copyright (c) 2026 Snowy",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "both",
        "compression": "lzma",
        "displayLanguageSelector": false,
        "startMenuFolder": "Neko Runner",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
